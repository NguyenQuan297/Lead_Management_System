# Lead Management System - Environment variables
# Copy this file to .env and set the values. Do not commit .env to version control.

# Default admin account (created on first run if no users exist)
DEFAULT_ADMIN_EMAIL=your_admin_email
DEFAULT_ADMIN_PASSWORD=change_this_password

# Registration codes (required for new user registration)
ADMIN_REGISTRATION_CODE=your_admin_registration_code
SALES_REGISTRATION_CODE=your_sales_registration_code

# Cookie encryption (optional; for session restore after reload)
COOKIES_PASSWORD=your_secret_for_cookie_encryption

# Auto-refresh interval in seconds (admin/sales see each other's changes). Default 10; set 3 for faster "live" testing.
# REFRESH_INTERVAL_SECONDS=3

# Base URL for login link (e.g. http://localhost:8501). Optional.
# BASE_URL=http://localhost:8501
